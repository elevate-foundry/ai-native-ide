# Aria LLM Configuration
# Get your API key at: https://openrouter.ai/keys

OPENROUTER_API_KEY=your_api_key_here

# Optional: Override default model
# ARIA_MODEL=anthropic/claude-3.5-sonnet
# ARIA_MODEL=openai/gpt-4o
# ARIA_MODEL=google/gemini-pro
# ARIA_MODEL=meta-llama/llama-3-70b-instruct

# Security: Auth token for API endpoints
# If not set, a random token is generated on each server start and printed to console.
# Set a fixed token for CI/scripts that need persistent access.
# ARIA_AUTH_TOKEN=your_fixed_token_here

# Set to 'disabled' to turn off auth (development only — never in production)
# ARIA_AUTH=disabled

# CORS: Comma-separated allowed origins (default: localhost:4173,localhost:3200)
# ARIA_CORS_ORIGINS=http://localhost:4173,http://localhost:3200
